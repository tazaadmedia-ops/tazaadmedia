{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemap-news.xml",
      "destination": "/api/sitemap-news"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/amp/:slug",
      "destination": "/api/amp?slug=:slug"
    },
    {
      "source": "/",
      "destination": "/api/ssr?type=home"
    },
    {
      "source": "/live/:slug",
      "destination": "/api/ssr?type=live&slug=:slug"
    },
    {
      "source": "/topic/:slug",
      "destination": "/api/ssr?type=category&slug=:slug"
    },
    {
      "source": "/author/:slug",
      "destination": "/api/ssr?type=author&slug=:slug"
    },
    {
      "source": "/:slug((?!api/|index.html|favicon.svg|default-og.jpg|logo.png|robots\\.txt|llms\\.txt|assets/|live/|topic/|author/|admin/|login|search|about|submit|contact|privacy|terms|sitemap|feed|amp|sitemap-news).*)",
      "destination": "/api/ssr?type=article&slug=:slug"
    },
    {
      "source": "/((?!api/|index.html|favicon.svg|default-og.jpg|logo.png|robots\\.txt|llms\\.txt|assets/|feed\\.xml|sitemap-news\\.xml|amp/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon.svg|logo.png|default-og.jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}