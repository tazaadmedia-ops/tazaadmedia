{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/",
      "destination": "/api/ssr?type=home"
    },
    {
      "source": "/article/live/:slug",
      "destination": "/api/ssr?type=live&slug=:slug"
    },
    {
      "source": "/article/:slug",
      "destination": "/api/ssr?type=article&slug=:slug"
    },
    {
      "source": "/category/:slug",
      "destination": "/api/ssr?type=category&slug=:slug"
    },
    {
      "source": "/author/:slug",
      "destination": "/api/ssr?type=author&slug=:slug"
    },
    {
      "source": "/((?!api/|index.html|favicon.svg|default-og.jpg|logo.png|assets/).*)",
      "destination": "/index.html"
    }
  ]
}